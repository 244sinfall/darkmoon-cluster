# Optional. Defaults to the repository root inferred by the scripts.
DARKMOON_REPO_ROOT=.

# Base output root. render_cluster.py writes to ./cluster below this path;
# flatten_secrets.py writes to ./secrets below this path.
DARKMOON_OUTPUT_ROOT=./.local/tmp

# Argo CD root kustomization to render first.
DARKMOON_CLUSTER_ROOT_PATH=clusters/darkmoon/root

# Comma-separated source repo URLs that should be rendered as local paths.
DARKMOON_LOCAL_REPO_URLS=git@github.com:244sinfall/darkmoon-cluster.git,https://github.com/244sinfall/darkmoon-cluster.git

# Local tool paths. Use names from PATH or repo-relative paths.
KUSTOMIZE_BIN=kustomize
KSOPS_BIN=ksops
SOPS_BIN=sops

# Required for decrypting SOPS files referenced by KSOPS generators.
SOPS_AGE_KEY_FILE=./.local/sops/age-key.txt

# Set false if you want repeated runs to merge with existing output.
DARKMOON_CLEAN_OUTPUT=true
